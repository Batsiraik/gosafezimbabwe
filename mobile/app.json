{
  "expo": {
    "name": "GO SAFE",
    "slug": "gosafe-mobile",
    "newArchEnabled": false,
    "version": "6.0.6",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "gosafe",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#785a0c"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gosafeappzw.app",
      "buildNumber": "2",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "versionCode": 69,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBgmR8kPB7vmagxIzRdr_EfPjxvjJ4hx6c"
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#785a0c"
      },
      "package": "com.gosafeappzw.app",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "androidDefaultChannelId": "default",
          "sounds": [
            "./assets/sounds/notification_sound.mp3"
          ]
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow GO SAFE to access your photos for license and vehicle images."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow GO SAFE to use your location for ride and parcel pickup."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25",
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0"
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "165365ec-9e2f-46b4-8098-ee94805b3a49"
      },
      "googleMapsApiKey": "AIzaSyBgmR8kPB7vmagxIzRdr_EfPjxvjJ4hx6c"
    }
  }
}
