# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Expo / React Native app lives in mobile/ — must be tracked for EAS Build (iOS/Android cloud builds).
# Ignore local secrets and deps inside mobile:
mobile/node_modules/
mobile/android/local.properties
mobile/android/keystore.properties
mobile/android/app/*.p12
mobile/android/app/*.jks
mobile/android/app/*.keystore
mobile/.env
mobile/.env.*

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# Firebase service account keys (NEVER commit these!)
*-firebase-adminsdk*.json
firebase-service-account*.json
*service-account*.json

# Android keystore files (NEVER commit these!)
*.jks
*.keystore
*.p12
android/keystore.properties
android/app/*.jks
android/app/*.keystore
# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma
